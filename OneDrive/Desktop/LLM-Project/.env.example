HOST=127.0.0.1
PORT=8000

# Runtime profile: local-dev | api-fast | api-accurate
CONTRACTIQ_PROFILE=local-dev

# Comma-separated API keys used when profile requires auth
CONTRACTIQ_API_KEYS=

# Redis distributed state
CONTRACTIQ_REDIS_ENABLED=false
CONTRACTIQ_REDIS_URL=redis://localhost:6379/0

# OpenTelemetry export
CONTRACTIQ_OTEL_ENABLED=false
CONTRACTIQ_OTEL_SERVICE_NAME=contractiq-api
CONTRACTIQ_OTEL_EXPORTER=otlp
CONTRACTIQ_OTEL_OTLP_ENDPOINT=http://localhost:4318/v1/traces
CONTRACTIQ_OTEL_PROMETHEUS_PORT=9464

# Tamper-evident audit log signing secret (set strong secret in non-dev environments)
CONTRACTIQ_AUDIT_SIGNING_SECRET=change-me

# Groq - free at console.groq.com
GROQ_API_KEY=

# Gemini - free at aistudio.google.com
GEMINI_API_KEY=

# HuggingFace - free at huggingface.co
HF_TOKEN=

# Local model + vector settings
OLLAMA_MODEL=deepseek-r1
GROQ_MODEL=llama-3.1-70b-versatile
GEMINI_MODEL=gemini-1.5-flash
CHROMA_PATH=./contract_db

# Optional local ML classifier settings
# Backends: tfidf (fast, no GPU) | legal-bert (best accuracy) | sentence-transformer
CONTRACTIQ_LEGAL_MODEL_ENABLED=true
CONTRACTIQ_LEGAL_MODEL_PATH=./models/legal_risk_model.joblib
CONTRACTIQ_LEGAL_MODEL_MIN_CONFIDENCE=0.35
